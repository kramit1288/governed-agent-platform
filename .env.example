API_PORT=8000
CONSOLE_PORT=3000
AI_GATEWAY_DEFAULT_PROVIDER=openai
AI_GATEWAY_FALLBACK_PROVIDER=anthropic
AI_GATEWAY_ENABLE_FALLBACK=true
